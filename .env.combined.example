# ─────────────────────────────────────────────────────────────────────────────
# Combined Paperclip + OpenClaw deployment
# Copy this to .env.combined and fill in the values marked REQUIRED.
#
# Generate random secrets with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────


# ─── REQUIRED: secrets ───────────────────────────────────────────────────────

# Paperclip session signing secret (any long random string)
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# OpenClaw gateway auth token — Paperclip presents this when connecting
OPENCLAW_GATEWAY_TOKEN=replace-with-openssl-rand-hex-32


# ─── REQUIRED: LLM provider keys ─────────────────────────────────────────────

# Claude Code (CEO agent) — needs Anthropic key
ANTHROPIC_API_KEY=sk-ant-...

# Codex/GPT agents on OpenClaw — needs OpenAI key
OPENAI_API_KEY=sk-...


# ─── Post-setup: Paperclip board API key ─────────────────────────────────────
# After the stack is running:
#   1. Open http://localhost:3100 → create your account
#   2. Settings → API Keys → create a key with "agent" role
#   3. Paste it here, then: docker compose -f docker-compose.combined.yml restart openclaw-gateway

PAPERCLIP_BOARD_API_KEY=


# ─── URLs ────────────────────────────────────────────────────────────────────

# Public URL shown in Paperclip emails/links (change for remote deployments)
PAPERCLIP_PUBLIC_URL=http://localhost:3100


# ─── Ports (optional overrides) ──────────────────────────────────────────────

# PAPERCLIP_PORT=3100
# OPENCLAW_GATEWAY_PORT=18789


# ─── Build paths ─────────────────────────────────────────────────────────────

# Path to your OpenClaw fork source (used by docker-compose.combined.yml build)
# Default: ../../OpenClaw/openclaw (relative to the paperclip repo root)
# OPENCLAW_BUILD_CONTEXT=../../OpenClaw/openclaw


# ─── Timezone ────────────────────────────────────────────────────────────────

TZ=UTC
